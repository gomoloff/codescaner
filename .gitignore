```gitignore
# Build artifacts
bin/
obj/
*.dll
*.exe
*.pdb
*.so
*.dylib
*.class

# Dependencies
packages/
node_modules/
venv/
.venv/
__pycache__/
*.egg-info/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Logs
*.log

# Environment
.env
.env.local
*.env.*

# Test and coverage
coverage/
htmlcov/
*.coverage
.nyc_output/
test-results/

# OS files
.DS_Store
Thumbs.db

# Distribution / packaging
dist/
build/
target/
release/
debug/
```